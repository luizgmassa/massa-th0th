{
  "name": "@massa-ai/tools-api",
  "version": "1.2.1",
  "author": "luizgmassa",
  "description": "massa-ai REST API server - Semantic code search, memory, and context compression",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "massa-ai-api": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "start:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun --external pg --external @prisma/adapter-pg",
    "type-check": "tsc --noEmit",
    "test": "bun scripts/run-tests-isolated.ts"
  },
  "dependencies": {
    "@massa-ai/core": "workspace:*",
    "@massa-ai/shared": "workspace:*",
    "elysia": "^1.2.25",
    "@elysiajs/swagger": "^1.2.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/node": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "dotenv": "^17.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luizgmassa/massa-ai"
  }
}

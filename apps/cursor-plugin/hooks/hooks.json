{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook session-start", "_massaAiOwned": true }
    ],
    "sessionEnd": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook stop", "_massaAiOwned": true }
    ],
    "beforeSubmitPrompt": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook user-prompt-submit", "_massaAiOwned": true }
    ],
    "preToolUse": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook pre-tool-use", "_massaAiOwned": true }
    ],
    "postToolUse": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook post-tool-use", "_massaAiOwned": true }
    ],
    "preCompact": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook pre-compact", "_massaAiOwned": true }
    ],
    "stop": [
      { "command": "<PLUGIN_DIR>/hooks/massa-ai-hook stop", "_massaAiOwned": true }
    ]
  }
}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_description": "massa-th0th plugin settings template. Merge into your user or project settings.json.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "massa-th0th-session-hint"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "massa-th0th-pre-compact"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__massa-th0th__list_projects",
      "mcp__massa-th0th__project_map",
      "mcp__massa-th0th__index_status",
      "mcp__massa-th0th__analytics",
      "mcp__massa-th0th__search",
      "mcp__massa-th0th__search_definitions",
      "mcp__massa-th0th__go_to_definition",
      "mcp__massa-th0th__get_references"
    ]
  }
}

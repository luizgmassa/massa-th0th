{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_description": "massa-th0th plugin settings template. Merge the 'hooks' block into your project (.claude/settings.json) or user (~/.claude/settings.json) settings. The single massa-th0th-hook binary replaces the 7 shell scripts; it fire-and-forgets POST lifecycle observations to the Tools API, always exits 0, and never blocks the agent. Set CLAUDE_PLUGIN_ROOT to the repo root, or replace it with an absolute path to apps/claude-plugin. Pass the event type as the first argument (session-start, user-prompt-submit, post-tool-use, pre-compact, stop).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/massa-th0th-hook.ts\" session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/massa-th0th-hook.ts\" user-prompt-submit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/massa-th0th-hook.ts\" post-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/massa-th0th-hook.ts\" stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/massa-th0th-hook.ts\" pre-compact"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__massa-th0th__list_projects",
      "mcp__massa-th0th__project_map",
      "mcp__massa-th0th__index_status",
      "mcp__massa-th0th__analytics",
      "mcp__massa-th0th__search",
      "mcp__massa-th0th__search_definitions",
      "mcp__massa-th0th__go_to_definition",
      "mcp__massa-th0th__get_references"
    ]
  }
}

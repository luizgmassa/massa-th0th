{
  "name": "@massa-th0th/mcp-client",
  "version": "1.1.0",
  "description": "massa-th0th MCP server - Semantic code search, memory, and context compression via Model Context Protocol",
  "author": "luizgmassa",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "massa-th0th": "dist/index.js",
    "massa-th0th-config": "dist/config-cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts src/config-cli.ts --outdir=dist --target=bun",
    "test": "bun test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@massa-th0th/core": "workspace:*",
    "@massa-th0th/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.2",
    "typescript": "^5.8.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luizgmassa/massa-th0th"
  }
}

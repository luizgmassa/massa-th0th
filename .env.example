# ============================================
# massa-ai - Environment Configuration
# ============================================
# Copy this file to .env and configure as needed
# For Docker: these values are used by docker-compose.yml
# ============================================

# ----------------------------------------------------------------------------
# Docker Image Configuration
# ----------------------------------------------------------------------------
# Use specific version tags (e.g., api-0.1.0) or latest
MASSA_AI_API_IMAGE=massa/massa-ai:api-latest
MASSA_AI_MCP_IMAGE=massa/massa-ai:mcp-latest

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
MASSA_AI_API_PORT=3333
NODE_ENV=production

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL password (used by docker-compose to create the postgres container,
# and by DATABASE_URL below in both Docker and native modes). Change before
# deploying to production.
POSTGRES_PASSWORD=massa_ai_password

# PostgreSQL connection URL.
#   Docker mode: assembled from the password above in docker-compose.yml
#                (postgresql://massa_ai:${POSTGRES_PASSWORD}@localhost:5432/massa_ai)
#   Native mode: installed via Homebrew postgresql@17 (or your distro's package)
#                by ./scripts/setup-native-postgres.sh — same URL shape.
#   Production:  use a secrets manager and inject DATABASE_URL directly.
DATABASE_URL=postgresql://massa_ai:massa_ai_password@localhost:5432/massa_ai

# Non-interactive installer DB choice: native | docker
#MASSA_AI_DB_BACKEND=native

# PostgreSQL port exposed on the host (defaults to 5432; Docker mode maps the
# container port to this host port).
MASSA_AI_POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Logging & Metrics
# ----------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_METRICS=true

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
L1_CACHE_MAX_SIZE=104857600  # 100MB in bytes
L1_CACHE_TTL=300             # 5 minutes
L2_CACHE_MAX_SIZE=524288000  # 500MB in bytes
L2_CACHE_TTL=3600            # 1 hour

# ----------------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------------
MIN_TOKENS_FOR_COMPRESSION=100
TARGET_COMPRESSION_RATIO=0.7  # 70% reduction

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
REQUESTS_PER_MINUTE=60
TOKENS_PER_MINUTE=100000

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
MAX_INPUT_LENGTH=50000
SANITIZE_INPUTS=true

# ----------------------------------------------------------------------------
# Embedding Providers Configuration
# ----------------------------------------------------------------------------

# === Provider Selection ===
# Set EMBEDDING_PROVIDER to force a specific provider:
#   - ollama  (local, no API key needed) - DEFAULT
#   - google  (requires GOOGLE_GENERATIVE_AI_API_KEY)
#   - mistral (requires MISTRAL_API_KEY)
#   - vercel  (Vercel AI Gateway — requires AI_GATEWAY_API_KEY)
#   - litellm (LiteLLM proxy — requires LITELLM_BASE_URL)
#   - custom  (OpenAI-compatible API — requires CUSTOM_EMBEDDING_BASE_URL)
# If not set, defaults to Ollama
#EMBEDDING_PROVIDER=ollama

# === Vercel AI Gateway (Cloud proxy to many providers) ===
# Uses the native @ai-sdk/gateway provider (endpoint: /v3/ai/embedding-model).
# Browse models: https://vercel.com/ai-gateway/models?capabilities=embedding
#
# Model choice — keep in sync with VERCEL_EMBEDDING_DIMENSIONS and the matching
# vector_documents_<N>d Postgres table:
#   openai/text-embedding-3-small    → 1536  (cheapest, multi-provider, reliable)
#   openai/text-embedding-3-large    → 3072  (strongest general, multi-provider)
#   voyage/voyage-code-3             → 1024  (SOTA for code, voyage-only)
#   alibaba/qwen3-embedding-8b       → 4096  (deepinfra-only, uses BQ path)
#EMBEDDING_PROVIDER=vercel
#AI_GATEWAY_API_KEY=your_vercel_ai_gateway_api_key_here
#VERCEL_EMBEDDING_MODEL=openai/text-embedding-3-small
#VERCEL_EMBEDDING_DIMENSIONS=1536

# VERCEL_AI_GATEWAY_URL only needed to point at a staging/proxy endpoint.
# Do NOT set it to the /v1 OpenAI-compat URL — the native gateway uses /v3/ai.
#VERCEL_AI_GATEWAY_URL=
#VERCEL_EMBEDDING_MAX_CHARS=8000

# === Google Embeddings (Cloud) ===
#GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
#GOOGLE_EMBEDDING_MODEL=gemini-embedding-001  # 3072 dimensions

# === Ollama (Local - Default) ===
# For Docker: use http://host.docker.internal:11434
# For local dev: use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b
OLLAMA_EMBEDDING_DIMENSIONS=4096

# Alternative Ollama models (default is qwen3-embedding:8b / 4096d):
# OLLAMA_EMBEDDING_MODEL=bge-m3                # 1024d — lighter/faster, lower recall
# OLLAMA_EMBEDDING_DIMENSIONS=1024
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b  # 1024d — fast, better quality than bge-m3
# OLLAMA_EMBEDDING_DIMENSIONS=1024

# Max characters sent per text to the embedding model.
# Defaults are model-aware: qwen3-embedding=8000, bge-m3=4000.
# Only override if the Ollama Modelfile has PARAMETER num_ctx set high enough.
# qwen3-embedding with num_ctx=32768 can safely go up to ~16000 chars.
#OLLAMA_EMBEDDING_MAX_CHARS=8000
#EMBEDDING_MAX_CHARS=

# HNSW index parameters (PostgreSQL vector store only).
# Higher efConstruction = better recall, slower one-time index build.
# Defaults in code: m=16, efConstruction=128 (recommended for 4096d qwen3).
#POSTGRES_HNSW_M=16
#POSTGRES_HNSW_EF_CONSTRUCTION=128
#POSTGRES_IVFFLAT_LISTS=100

# === Mistral Embeddings (Cloud) ===
#MISTRAL_API_KEY=
# Text embeddings - General purpose (1024 dimensions)
#MISTRAL_TEXT_EMBEDDING_MODEL=mistral-embed
# Code embeddings - Optimized for code (1536D default, up to 3072D)
#MISTRAL_CODE_EMBEDDING_MODEL=codestral-embed

# === LiteLLM Proxy (OpenAI-compatible) ===
# Proxy local/privado para múltiplos modelos via LiteLLM
#LITELLM_BASE_URL=https://llm.example.local/v1
#LITELLM_API_KEY=
#LITELLM_EMBEDDING_MODEL=embed-v-4-0
#LITELLM_EMBEDDING_DIMENSIONS=1024
#LITELLM_EMBEDDING_TIMEOUT=60000
#LITELLM_EMBEDDING_MAX_CHARS=8000
#LITELLM_EMBEDDING_RPM=
#LITELLM_EMBEDDING_BATCH_SIZE=

# === Custom Provider (OpenAI-compatible API) ===
# Supports any OpenAI-compatible endpoint: LM Studio, LocalAI, vLLM, Together.ai, Groq, etc.
# Requires CUSTOM_EMBEDDING_BASE_URL at minimum; CUSTOM_API_KEY is optional (sent as "none" if unset)
#CUSTOM_EMBEDDING_BASE_URL=http://localhost:1234/v1
#CUSTOM_API_KEY=
#CUSTOM_EMBEDDING_MODEL=text-embedding-3-small
#CUSTOM_EMBEDDING_DIMENSIONS=1536
#CUSTOM_EMBEDDING_TIMEOUT=60000
#CUSTOM_EMBEDDING_MAX_CHARS=8000
#CUSTOM_EMBEDDING_RPM=
#CUSTOM_EMBEDDING_BATCH_SIZE=

# ============================================================================
# Local-first LLM (Ollama) — OPTIONAL, all default OFF, silent degrade
# ============================================================================
# Drives: hook→memory consolidation, handoff-summary polish, query
# understanding, rerank, auto-importance. Everything still works (rule-based)
# when these are off. Pull the models: `ollama pull qwen2.5:7b-instruct`
# and `ollama pull qwen2.5-coder:7b`.
# Master switch — gate all LLM-driven features. Default false. install.sh
# auto-sets this true when qwen2.5:7b-instruct is detected in Ollama's /api/tags.
RLM_LLM_ENABLED=false
# OpenAI-compatible endpoint. Default http://localhost:11434/v1 (Ollama).
RLM_LLM_BASE_URL=http://localhost:11434/v1
# API key (sent as Authorization: Bearer). Default "ollama" for local.
RLM_LLM_API_KEY=ollama
# Instruction LLM (NL-judgment sites: consolidation, salience, handoff polish,
# query rewrite, HyDE). Default qwen2.5:7b-instruct (non-thinking instruct).
RLM_LLM_MODEL=qwen2.5:7b-instruct
# Code-oriented LLM (bootstrap seed summarization, reranker, code compression).
# Selected per-call via modelRole:"code". Default qwen2.5-coder:7b.
RLM_LLM_CODE_MODEL=qwen2.5-coder:7b
# Sampling temperature. Default 0.2.
RLM_LLM_TEMPERATURE=0.2
# Max output tokens per call. Default 8000 (thinking tokens count toward this).
RLM_LLM_MAX_OUTPUT_TOKENS=8000
# Per-call timeout in ms. Default 90000 (thinking models are slower).
RLM_LLM_TIMEOUT_MS=90000

# ----------------------------------------------------------------------------
# Passive capture (Claude Code hooks)
# ----------------------------------------------------------------------------
# Enable the /api/v1/hook ingestion endpoint. Default true.
HOOKS_ENABLED=true
# Max bytes accepted per hook payload. Default 65536.
HOOKS_MAX_PAYLOAD_BYTES=65536
# Saturation threshold — /api/v1/hook returns 429 once exceeded. Default 256.
HOOKS_QUEUE_MAX_PENDING=256
# LLM-driven observation→memory summarization bridge. No-ops when
# RLM_LLM_ENABLED=false (observations stored raw). Default true.
HOOKS_BRIDGE_ENABLED=true
# Min observations before a consolidation batch fires. Default 8.
HOOKS_BRIDGE_MIN_OBS=8
# Min interval between batches, in ms. Default 300000 (5 min).
HOOKS_BRIDGE_MIN_INTERVAL_MS=300000
# Max observations folded into one batch. Default 8.
HOOKS_BRIDGE_MAX_WINDOW=8

# ----------------------------------------------------------------------------
# Cross-session handoffs
# ----------------------------------------------------------------------------
# Enable handoff_begin/accept/cancel. begin/accept/cancel have no LLM
# dep. Default true.
HANDOFFS_ENABLED=true

# ----------------------------------------------------------------------------
# Project bootstrap
# ----------------------------------------------------------------------------
# Rule-based + LLM seed memories from git log/README/docs/centrality. The
# scan + rule-based seed have no LLM dep; LLM enrichment inherits
# RLM_LLM_ENABLED. Default true.
BOOTSTRAP_ENABLED=true
# Max seed memories to write. Default 8.
BOOTSTRAP_MAX_SEED_MEMORIES=8
# Top-N central files (PageRank) to seed. Default 10.
BOOTSTRAP_CENTRALITY_LIMIT=10
# Git log commits to scan. Default 20.
BOOTSTRAP_GIT_LOG_LIMIT=20
# Re-bootstrap when the repo changes materially. Default true.
BOOTSTRAP_REFRESH_ENABLED=true

# ----------------------------------------------------------------------------
# Auto-improvement (proposals)
# ----------------------------------------------------------------------------
# Rule-based pattern detection (no LLM dep); LLM enrichment inherits
# RLM_LLM_ENABLED. Default true.
AUTO_IMPROVE_ENABLED=true
# false = auto-approve proposals silently. true = surface via
# list_proposals / approve_proposal. Default false.
AUTO_IMPROVE_REVIEW_GATE=false
# Min observations before a proposal is generated. Default 8.
AUTO_IMPROVE_MIN_OBS=8
# Min interval between proposal scans, in ms. Default 300000 (5 min).
AUTO_IMPROVE_MIN_INTERVAL_MS=300000
# Max observations scanned per window. Default 16.
AUTO_IMPROVE_MAX_WINDOW=16
# Min query-recurrence hits to flag a pattern. Default 3.
AUTO_IMPROVE_MIN_QUERY_HITS=3
# Min file-recurrence hits to flag a pattern. Default 3.
AUTO_IMPROVE_MIN_FILE_HITS=3
# Min fix-recurrence hits to flag a pattern. Default 2.
AUTO_IMPROVE_MIN_FIX_HITS=2

# ----------------------------------------------------------------------------
# Auto importance/salience (LLM) — OPTIONAL, default OFF, silent degrade
# ----------------------------------------------------------------------------
# Scores importance on remember (only when the caller omits it). Requires
# RLM_LLM_ENABLED=true. Default false; install.sh auto-enables it alongside
# RLM_LLM_ENABLED when qwen2.5:7b-instruct is detected in Ollama.
AUTO_IMPORTANCE_ENABLED=false

# ----------------------------------------------------------------------------
# Search quality knobs — query understanding + rerank are OPTIONAL (OFF)
# ----------------------------------------------------------------------------
# LLM query rewrite + HyDE. Default false; requires RLM_LLM_ENABLED=true.
SEARCH_QUERY_UNDERSTANDING_ENABLED=false
# Gate only the extra HyDE LLM call (rewrite still runs when enabled &&
# hydeEnabled=false). Default true.
SEARCH_QUERY_UNDERSTANDING_HYDE_ENABLED=true
# Per-(query, projectId) cache TTL, in ms. Default 300000 (5 min).
SEARCH_QUERY_UNDERSTANDING_CACHE_TTL_MS=300000
# Cache max entries. Default 256.
SEARCH_QUERY_UNDERSTANDING_CACHE_MAX_SIZE=256
# LLM-judge rerank over top-K after centrality boost. Default false; requires
# RLM_LLM_ENABLED=true.
SEARCH_RERANK_ENABLED=false
# Top-K re-scored by the judge. Default 50.
SEARCH_RERANK_WINDOW=50
# Max files an auto-reindex (latency-sensitive) path will sync before
# deferring. Default 200.
AUTOREINDEX_MAX_FILES=200

# ----------------------------------------------------------------------------
# Web UI (read-only memory/search/handoff/checkpoint browser)
# ----------------------------------------------------------------------------
# Served by the Tools API at /ui. Read in apps/tools-api/src/routes/web-ui.ts;
# "false" or "0" returns 404 for the whole /ui prefix. Default true.
WEB_UI_ENABLED=true

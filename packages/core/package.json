{
  "name": "@massa-th0th/core",
  "version": "1.0.0",
  "author": "luizgmassa",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "bundledDependencies": [
    "tree-sitter"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "default": "./dist/controllers/index.js"
    }
  },
  "scripts": {
    "prebuild": "bunx prisma generate",
    "build": "rm -f tsconfig.tsbuildinfo && tsc && cp -r src/generated dist/",
    "dev": "bunx tsc --watch",
    "clean": "rm -rf dist",
    "test": "bun scripts/run-tests-isolated.ts",
    "test:unit": "bun scripts/run-tests-isolated.ts --unit",
    "test:e2e": "RUN_E2E=1 bun scripts/run-tests-isolated.ts --e2e",
    "test:integration": "bun test src/__tests__/integration/real-api.test.ts",
    "test:watch": "bun test --watch",
    "bench:fixture:sicad": "bun run src/scripts/create-sicad-beir-fixture.ts",
    "bench:beir": "bun run src/scripts/beir-benchmark.ts"
  },
  "dependencies": {
    "@ai-sdk/cohere": "^3.0.17",
    "@ai-sdk/google": "^3.0.19",
    "@ai-sdk/mistral": "^3.0.17",
    "@ai-sdk/openai": "^3.0.24",
    "@massa-th0th/shared": "1.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@tree-sitter-grammars/tree-sitter-kotlin": "1.1.0",
    "@tree-sitter-grammars/tree-sitter-lua": "0.4.1",
    "@tree-sitter-grammars/tree-sitter-markdown": "0.3.2",
    "@tree-sitter-grammars/tree-sitter-yaml": "0.7.1",
    "@tree-sitter-grammars/tree-sitter-zig": "1.1.2",
    "@toon-format/toon": "^2.1.0",
    "@huggingface/transformers": "^3.0.0",
    "ai": "^6.0.66",
    "glob": "^10.0.0",
    "ignore": "^5.3.0",
    "minimatch": "^9.0.0",
    "ollama-ai-provider": "1.2.0",
    "pg": "^8.20.0",
    "tree-sitter": "0.25.0",
    "tree-sitter-c": "0.24.1",
    "tree-sitter-c-sharp": "0.23.5",
    "tree-sitter-clojure-orchard": "0.2.5",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-dart": "github:UserNobody14/tree-sitter-dart#be07cf7118d3dba06236a3f19541685a68209934",
    "tree-sitter-elixir": "0.3.5",
    "tree-sitter-erlang": "github:WhatsApp/tree-sitter-erlang#836aa2b6c3af2c7cef3f84049b0ed6d44485a870",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-haskell": "0.23.1",
    "tree-sitter-html": "0.23.2",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-json": "0.24.8",
    "tree-sitter-ocaml": "0.24.2",
    "tree-sitter-php": "0.24.2",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-scala": "0.24.0",
    "tree-sitter-swift": "0.7.1",
    "tree-sitter-typescript": "0.23.2",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/glob": "^8.1.0",
    "@types/node": "^25.2.2",
    "@types/turndown": "^5.0.6",
    "dotenv": "^17.2.4",
    "prisma": "^7.5.0",
    "typescript": "^5.8.3"
  }
}

// Prisma Schema para PostgreSQL database
// Base de dados consolidada para queries e relatórios
// Read-only - dados sincronizados via triggers dos bancos operacionais

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// Memories (sincronizado de PostgreSQL memories table)
// ========================================
model Memory {
  id            String    @id
  content       String
  type          String    // preference, conversation, code, decision, pattern
  level         Int
  userId        String?   @map("user_id")
  sessionId     String?   @map("session_id")
  projectId     String?   @map("project_id")
  agentId       String?   @map("agent_id")
  importance    Float     @default(0.5)
  tags          String[]  @default([]) // Migrated from CSV to native array
  embedding     Bytes?    // Vector embedding stored as bytes (cache only, not for similarity search)
  metadata      Json?     // Migrated from String to Json for structured queries
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accessCount   Int       @default(0) @map("access_count")
  lastAccessed  DateTime? @map("last_accessed")
  // Phase 1: pinned memories are decay-exempt.
  pinned        Boolean   @default(false) @map("pinned")
  // Phase 1: soft-delete tombstone. Null = live row.
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  edgesFrom MemoryEdge[] @relation("EdgeFrom")
  edgesTo   MemoryEdge[] @relation("EdgeTo")

  @@index([userId])
  @@index([sessionId])
  @@index([projectId])
  @@index([agentId])
  @@index([type])
  @@index([importance(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([tags]) // GIN index for array containment queries
  @@index([deletedAt]) // sparse — most rows null
  @@map("memories")
}

// ========================================
// Projects (sincronizado de PostgreSQL vector table)
// ========================================
model Project {
  id            String    @id @default(cuid())
  projectId     String    @unique @map("project_id")
  path          String
  documentCount Int       @default(0) @map("document_count")
  totalSize     Int       @default(0) @map("total_size")
  lastIndexed   DateTime? @map("last_indexed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  documents Document[]

  @@index([lastIndexed(sort: Desc)])
  @@map("projects")
}

model Document {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  filePath   String   @map("file_path")
  fileType   String?  @map("file_type")
  size       Int      @default(0)
  indexedAt  DateTime @map("indexed_at")
  
  project    Project  @relation(fields: [projectId], references: [projectId])

  @@index([projectId])
  @@index([fileType])
  @@index([indexedAt(sort: Desc)])
  @@map("documents")
}

// ========================================
// Search Analytics
// ========================================
model SearchQuery {
  id           String   @id @default(cuid())
  query        String
  projectId    String?  @map("project_id")
  resultsCount Int      @default(0) @map("results_count")
  duration     Int      // milliseconds
  cacheHit     Boolean  @default(false) @map("cache_hit")
  timestamp    DateTime @default(now())

  @@index([projectId])
  @@index([timestamp(sort: Desc)])
  @@map("search_queries")
}

model CacheStats {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  queryHash String   @map("query_hash")
  hitCount  Int      @default(0) @map("hit_count")
  createdAt DateTime @default(now()) @map("created_at")
  lastHitAt DateTime @default(now()) @map("last_hit_at")

  @@unique([projectId, queryHash])
  @@index([projectId])
  @@index([hitCount(sort: Desc)])
  @@map("cache_stats")
}

// ========================================
// Symbol Database Tables
// ========================================

// Workspace / Project registry
model Workspace {
  projectId      String    @id @map("project_id")
  projectPath    String    @map("project_path")
  displayName    String?   @map("display_name")
  status         String    @default("pending") // pending, indexing, indexed, error
  lastIndexedAt  DateTime? @map("last_indexed_at")
  lastError      String?   @map("last_error")
  filesCount     Int       @default(0) @map("files_count")
  chunksCount    Int       @default(0) @map("chunks_count")
  symbolsCount   Int       @default(0) @map("symbols_count")
  activeGraphGenerationId  String?   @map("active_graph_generation_id")
  pendingGraphGenerationId String?   @map("pending_graph_generation_id")
  graphLeaseToken     String?   @map("graph_lease_token")
  graphLeaseExpiresAt DateTime? @map("graph_lease_expires_at")
  graphLeaseHeartbeatAt DateTime? @map("graph_lease_heartbeat_at")
  activeFilesCount       Int @default(0) @map("active_files_count")
  activeDefinitionsCount Int @default(0) @map("active_definitions_count")
  activeReferencesCount  Int @default(0) @map("active_references_count")
  activeImportsCount     Int @default(0) @map("active_imports_count")
  activeCentralityCount  Int @default(0) @map("active_centrality_count")
  activeDiagnosticsCount Int @default(0) @map("active_diagnostics_count")
  activeRecoveredCount   Int @default(0) @map("active_recovered_count")
  activeHardFailuresCount Int @default(0) @map("active_hard_failures_count")
  activeStaleFilesCount  Int @default(0) @map("active_stale_files_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  files        SymbolFile[]
  definitions  SymbolDefinition[]
  references   SymbolReference[]
  imports      SymbolImport[]
  centralities SymbolCentrality[]
  graphGenerations GraphGeneration[] @relation("GenerationWorkspace")
  identityAliases ProjectIdentityAlias[] @relation("ProjectIdentityAliasTarget")
  activeGraphGeneration GraphGeneration? @relation("WorkspaceActiveGraphGeneration", fields: [projectId, activeGraphGenerationId], references: [projectId, id], onDelete: SetNull)
  pendingGraphGeneration GraphGeneration? @relation("WorkspacePendingGraphGeneration", fields: [projectId, pendingGraphGenerationId], references: [projectId, id], onDelete: SetNull)

  @@index([status])
  @@index([projectPath])
  @@index([activeGraphGenerationId])
  @@index([pendingGraphGenerationId])
  @@index([graphLeaseExpiresAt])
  @@map("workspaces")
}

model GraphGeneration {
  id                    String   @id
  projectId             String   @map("project_id")
  status                String   @default("pending")
  fingerprint           String
  inputSnapshotHash     String   @map("input_snapshot_hash")
  expectedActiveId      String?  @map("expected_active_id")
  leaseToken            String?  @map("lease_token")
  leaseExpiresAt        DateTime? @map("lease_expires_at")
  expectedFilesCount    Int      @default(0) @map("expected_files_count")
  completedFilesCount   Int      @default(0) @map("completed_files_count")
  filesCount            Int      @default(0) @map("files_count")
  definitionsCount      Int      @default(0) @map("definitions_count")
  referencesCount       Int      @default(0) @map("references_count")
  importsCount          Int      @default(0) @map("imports_count")
  centralityCount       Int      @default(0) @map("centrality_count")
  diagnosticsCount      Int      @default(0) @map("diagnostics_count")
  recoveredCount        Int      @default(0) @map("recovered_count")
  hardFailuresCount     Int      @default(0) @map("hard_failures_count")
  staleFilesCount       Int      @default(0) @map("stale_files_count")
  failureReason         String?  @map("failure_reason")
  startedAt             DateTime @default(now()) @map("started_at")
  completedAt           DateTime? @map("completed_at")
  activatedAt           DateTime? @map("activated_at")
  supersededAt          DateTime? @map("superseded_at")

  workspace Workspace @relation("GenerationWorkspace", fields: [projectId], references: [projectId], onDelete: Cascade)
  files SymbolFile[]
  definitions SymbolDefinition[]
  references SymbolReference[]
  imports SymbolImport[]
  centralities SymbolCentrality[]
  activeForWorkspaces Workspace[] @relation("WorkspaceActiveGraphGeneration")
  pendingForWorkspaces Workspace[] @relation("WorkspacePendingGraphGeneration")
  @@unique([projectId, id])
  @@index([projectId, status])
  @@index([projectId, fingerprint])
  @@index([leaseExpiresAt])
  @@map("graph_generations")
}

// File fingerprints - tracks per-file content hash
model SymbolFile {
  projectId    String   @map("project_id")
  generationId String   @map("generation_id")
  relativePath String   @map("relative_path")
  contentHash  String   @map("content_hash")
  mtime        BigInt
  size         Int      @default(0)
  indexedAt    DateTime @map("indexed_at")
  symbolCount  Int      @default(0) @map("symbol_count")
  chunkCount   Int      @default(0) @map("chunk_count")
  language     String?
  dialect      String?
  grammarVersion String? @map("grammar_version")
  queryPackVersion String? @map("query_pack_version")
  resolverVersion String? @map("resolver_version")
  parserStatus String @default("legacy") @map("parser_status")
  parserErrorCount Int @default(0) @map("parser_error_count")
  diagnostics Json @default("[]")
  isStale Boolean @default(false) @map("is_stale")
  lastKnownGoodGenerationId String? @map("last_known_good_generation_id")
  lastSuccessfulAt DateTime? @map("last_successful_at")

  workspace Workspace @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  generation GraphGeneration @relation(fields: [projectId, generationId], references: [projectId, id], onDelete: Cascade)

  @@id([projectId, generationId, relativePath])
  @@index([projectId, generationId])
  @@map("symbol_files")
}

// Symbol definitions - one row per symbol (function, class, variable, type, interface)
model SymbolDefinition {
  id         String   @map("id")
  projectId  String   @map("project_id")
  generationId String @map("generation_id")
  filePath   String   @map("file_path")
  name       String
  kind       String   // function, class, variable, type, interface, export
  lineStart  Int      @map("line_start")
  lineEnd    Int      @map("line_end")
  exported   Boolean  @default(false)
  docComment String?  @map("doc_comment")
  indexedAt  DateTime @map("indexed_at")
  qualifiedName String @map("qualified_name")
  canonicalSignature String? @map("canonical_signature")
  signatureHash String? @map("signature_hash")
  legacyFqn String @map("legacy_fqn")
  sourceSpan Json? @map("source_span")

  workspace Workspace @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  generation GraphGeneration @relation(fields: [projectId, generationId], references: [projectId, id], onDelete: Cascade)

  @@id([projectId, generationId, id])
  @@index([projectId, generationId])
  @@index([projectId, generationId, filePath])
  @@index([projectId, generationId, name])
  @@index([projectId, generationId, legacyFqn])
  @@map("symbol_definitions")
}

// Symbol references - one row per usage site (typed structural edge)
model SymbolReference {
  id         Int    @id @default(autoincrement())
  projectId  String @map("project_id")
  generationId String @map("generation_id")
  fromFile   String @map("from_file")
  fromLine   Int    @map("from_line")
  symbolName String @map("symbol_name")
  targetFqn  String? @map("target_fqn") // nullable: unresolved-target refs are retained (PostgreSQL parity)
  refKind    String @map("ref_kind") // call, type_ref, import, extend, implement, data_flow, http_call, emit, listen
  meta       Json?  // typed-edge metadata: { route?, event?, paramIndex?, callerFqn? }
  sourceSpan Json? @map("source_span")

  workspace Workspace @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  generation GraphGeneration @relation(fields: [projectId, generationId], references: [projectId, id], onDelete: Cascade)

  @@index([projectId, generationId])
  @@index([projectId, generationId, targetFqn]) // CRITICAL: find references query
  @@index([projectId, generationId, fromFile])
  @@index([projectId, generationId, refKind]) // typed-edge filtering by edge type
  @@map("symbol_references")
}

// Import edges - file-level dependency graph
model SymbolImport {
  id            Int      @id @default(autoincrement())
  projectId     String   @map("project_id")
  generationId  String   @map("generation_id")
  fromFile      String   @map("from_file")
  toFile        String?  @map("to_file")
  specifier     String
  importedNames String[] @default([]) @map("imported_names") // Migrated from CSV to text[] for GIN index queries
  isExternal    Boolean  @default(false) @map("is_external")
  isTypeOnly    Boolean  @default(false) @map("is_type_only")

  workspace Workspace @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  generation GraphGeneration @relation(fields: [projectId, generationId], references: [projectId, id], onDelete: Cascade)

  @@index([projectId, generationId, fromFile])
  @@index([projectId, generationId, toFile])
  @@index([importedNames]) // GIN index for "find imports of Symbol X"
  @@map("symbol_imports")
}

// Centrality scores - PageRank per file
model SymbolCentrality {
  projectId String   @map("project_id")
  generationId String @map("generation_id")
  filePath  String   @map("file_path")
  score     Float    @default(0)
  updatedAt DateTime @map("updated_at")

  workspace Workspace @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  generation GraphGeneration @relation(fields: [projectId, generationId], references: [projectId, id], onDelete: Cascade)

  @@id([projectId, generationId, filePath])
  @@map("symbol_centrality")
}

// ========================================
// Graph Store (Memory relationships)
// ========================================
model MemoryEdge {
  id         Int      @id @default(autoincrement())
  fromId     String   @map("from_id")
  toId       String   @map("to_id")
  edgeType   String   @map("edge_type") // relates_to, conflicts_with, depends_on, derived_from
  weight     Float    @default(1.0)
  metadata   Json?    // Migrated from String to Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Foreign Keys to prevent dangling edges
  fromMemory Memory @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toMemory   Memory @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, edgeType])
  @@index([fromId])
  @@index([toId])
  @@index([edgeType])
  @@map("memory_edges")
}

// ========================================
// Observations (Phase 3 — passive lifecycle capture)
// PostgreSQL-canonical; this model provides PG parity so a Postgres deployment
// can also store observations. The default local-first path uses the
// PgStore (PostgreSQL observations table) via the polymorphic factory.
//
// `source` = one of the six lifecycle event kinds (session-start, user-prompt,
// pre-tool-use, post-tool-use, pre-compact, session-end) — the raw hook trigger.
// `category` = derived semantic classification (~30 categories: files-read,
// git-changes, tasks, errors, decisions, etc.) — see ObservationExtractor.
// ========================================
model Observation {
  id          String   @id
  projectId   String   @map("project_id")
  sessionId   String?  @map("session_id")
  source      String // one of the six lifecycle event kinds
  category    String? // derived semantic category (Phase 3 C1); null = legacy
  payloadJson String   @map("payload_json")
  importance  Float
  createdAt   DateTime @default(now()) @map("created_at")
  agentId     String?  @map("agent_id")
  attributionSource String? @map("attribution_source")

  @@index([projectId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([sessionId, createdAt(sort: Desc)])
  @@map("observations")
}

// ========================================
// Handoff (Phase 6, G2) — cross-session handoff records.
// PostgreSQL deployments use PgHandoffStore; local deployments retain the
// PostgreSQL-canonical PostgreSQL handoffs table store via the polymorphic factory.
// ========================================
model Handoff {
  id               String    @id
  projectId        String    @map("project_id")
  sourceSessionId  String?   @map("source_session_id")
  targetAgent      String?   @map("target_agent")
  summary          String    @default("")
  openQuestionsJson String   @map("open_questions_json") @default("[]")
  nextStepsJson    String    @map("next_steps_json") @default("[]")
  filesJson        String    @map("files_json") @default("[]")
  status           String    @default("open") // open | accepted | expired
  createdAt        DateTime  @default(now()) @map("created_at")
  acceptedAt       DateTime? @map("accepted_at")

  @@index([projectId, status])
  @@index([targetAgent, status])
  @@index([createdAt(sort: Desc)])
  @@map("handoffs")
}

// ========================================
// Proposal (Phase 5, G7) — auto-improvement proposals.
// PostgreSQL deployments use PgProposalStore; local deployments retain the
// PostgreSQL-canonical PostgreSQL proposals table store via the polymorphic factory.
// ========================================
model Proposal {
  id              String    @id
  projectId       String    @map("project_id")
  kind            String    // memory.create | memory.update | memory.tag
  targetMemoryId  String?   @map("target_memory_id")
  payloadJson     String    @map("payload_json")
  rationale       String    @default("")
  status          String    @default("pending") // pending | approved | rejected
  createdAt       DateTime  @default(now()) @map("created_at")
  decidedAt       DateTime? @map("decided_at")

  @@index([projectId, status])
  @@index([createdAt(sort: Desc)])
  @@map("proposals")
}

// ========================================
// Embedding Cache
// ========================================
model EmbeddingCache {
  textHash   String   @id @map("text_hash")
  embedding  Bytes
  model      String   @default("nomic-embed-text")
  createdAt  DateTime @default(now()) @map("created_at")
  accessedAt DateTime @default(now()) @map("accessed_at")
  hitCount   Int      @default(1) @map("hit_count")

  @@index([model])
  @@index([accessedAt(sort: Desc)])
  @@map("embedding_cache")
}

// ========================================
// Vector Store - Multi-Dimension Support
// ========================================
// NOTE: Using Unsupported("vector") because Prisma doesn't natively support pgvector.
// Vector similarity queries (ORDER BY embedding <=> $1::vector) must use raw SQL.
// CRUD operations can use Prisma for type safety.

// Base template for vector documents - NOT USED DIRECTLY
// Dynamic tables created per dimension: vector_documents_1024d, vector_documents_1536d, vector_documents_3072d
model VectorDocument1024 {
  id         String                         @id
  projectId  String                         @map("project_id")
  content    String
  metadata   Json                           @default("{}")
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                       @default(now()) @map("created_at")
  updatedAt  DateTime                       @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("vector_documents_1024d")
}

model VectorDocument1536 {
  id         String                         @id
  projectId  String                         @map("project_id")
  content    String
  metadata   Json                           @default("{}")
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                       @default(now()) @map("created_at")
  updatedAt  DateTime                       @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("vector_documents_1536d")
}

model VectorDocument3072 {
  id         String                         @id
  projectId  String                         @map("project_id")
  content    String
  metadata   Json                           @default("{}")
  embedding  Unsupported("vector(3072)")?
  createdAt  DateTime                       @default(now()) @map("created_at")
  updatedAt  DateTime                       @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("vector_documents_3072d")
}

// Legacy table for backward compatibility (if exists)
model VectorDocumentLegacy {
  id         String                        @id
  projectId  String                        @map("project_id")
  content    String
  metadata   Json                          @default("{}")
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                      @default(now()) @map("created_at")
  updatedAt  DateTime                      @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("vector_documents")
}

// 4096-dimension table (qwen3-embedding) with binary quantization for HNSW indexing.
// pgvector HNSW supports any dimension on bit columns (bit_hamming_ops).
// Search strategy: Phase 1 ANN on embedding_bq → Phase 2 exact cosine re-rank on embedding.
model VectorDocument4096 {
  id          String                       @id
  projectId   String                       @map("project_id")
  content     String
  metadata    Json                         @default("{}")
  embedding   Unsupported("vector(4096)")?
  embeddingBq Unsupported("bit(4096)")?   @map("embedding_bq")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("vector_documents_4096d")
}

// ========================================
// Index Jobs (Phase 1, T9 — PG parity for the job store)
// Runtime state for async indexing jobs. PostgreSQL-canonical via PgStore
// (PostgreSQL index-jobs table); this model provides PG parity so a Postgres deployment can
// keep jobs in the same backend as the rest of the data plane. The factory
// (getJobStore) selects PgJobStore when DATABASE_URL is postgres, else
// PgStore. Timestamps are BigInt ms-epochs (parity with SymbolFile.mtime
// and the PostgreSQL store's INTEGER epoch columns).
// ========================================
model IndexJob {
  jobId         String  @id @map("job_id")
  projectId     String  @map("project_id")
  projectPath   String  @map("project_path")
  status        String // pending | running | completed | failed
  current       Int     @default(0)
  total         Int     @default(0)
  percentage    Int     @default(0)
  filesIndexed  Int?    @map("files_indexed")
  chunksIndexed Int?    @map("chunks_indexed")
  errors        Int?
  duration      Int?
  error         String?
  createdAt     BigInt  @map("created_at")
  startedAt     BigInt? @map("started_at")
  completedAt   BigInt? @map("completed_at")
  heartbeatAt   BigInt? @map("heartbeat_at")
  activatedGraphGenerationId String? @map("activated_graph_generation_id")
  parserDiagnosticsCount Int? @map("parser_diagnostics_count")
  parserRecoveredFiles Int? @map("parser_recovered_files")
  parserHardFailureFiles Int? @map("parser_hard_failure_files")
  parserStaleFiles Int? @map("parser_stale_files")
  parserLanguageCounts Json? @map("parser_language_counts")

  @@index([projectId])
  @@index([status])
  @@index([activatedGraphGenerationId])
  @@map("index_jobs")
}

// ========================================
// Scheduled Jobs (Phase 3, C2 — OS-level in-process scheduler)
// Durable job definitions for the cron-like scheduler. PostgreSQL-canonical via
// PgStore (PostgreSQL scheduled-jobs table); this model provides PG parity so
// a Postgres deployment can keep scheduler state in the same backend as the
// rest of the data plane. The factory (getScheduledJobStore) selects
// PgScheduledJobStore when DATABASE_URL is postgres, else PgStore.
// Timestamps are BigInt ms-epochs (parity with IndexJob and the PostgreSQL store's
// INTEGER epoch columns).
// ========================================
model ScheduledJob {
  id           String  @id @map("id")
  name         String
  jobKind      String  @map("job_kind")
  scheduleType String  @map("schedule_type") // "interval" | "cron"
  intervalMs   BigInt? @map("interval_ms")
  cron         String?
  nextRunAt    BigInt  @map("next_run_at")
  lastRunAt    BigInt  @default(0) @map("last_run_at")
  enabled      Int     @default(1)
  payload      String? // JSON

  // Wave 5 FR-13 / M-W5-02: success/failure split + crash-safe catch-up.
  // last_success_at — ms-epoch of the last SUCCESSFUL run (NULL until first success).
  // last_failure_at — ms-epoch of the last FAILED run (NULL until first failure).
  // consecutive_failures — failure streak counter (0 on success, ++ on failure).
  // last_error — truncated error message from the last failure (NULL on success).
  lastSuccessAt        BigInt? @map("last_success_at")
  lastFailureAt        BigInt? @map("last_failure_at")
  consecutiveFailures  Int     @default(0) @map("consecutive_failures")
  lastError            String? @map("last_error")

  @@index([enabled])
  @@index([nextRunAt])
  @@map("scheduled_jobs")
}

// ========================================
// Synapse Sessions (Phase 3, C4 — PG parity for the Synapse session store)
// Durable agent-session + working-memory buffer state for the cognitive
// modulation layer. PostgreSQL-canonical via PgStore
// (PostgreSQL sessions table); this model provides PG parity so a Postgres
// deployment persists Synapse state across process restarts (one-backend
// rule). The factory (getSessionStore) selects PgSynapseSessionStore when
// DATABASE_URL is postgres, else PgStore. Timestamps are BigInt
// ms-epochs (parity with IndexJob/ScheduledJob and the PostgreSQL store's INTEGER
// epoch columns). The buffer snapshot is a best-effort JSON blob; the live
// WorkingMemoryBuffer is a hot cache reconstructed fresh on load (refills
// naturally as the agent works — see session-store.ts design note).
// ========================================
model SynapseSession {
  sessionId           String  @id @map("session_id")
  agentId             String  @map("agent_id")
  workspaceId         String? @map("workspace_id")
  taskContext         String? @map("task_context")
  taskTokens          String? @map("task_tokens") // JSON array
  taskEmbedding       Bytes?  @map("task_embedding") // Float32 buffer
  ttlMs               BigInt  @map("ttl_ms")
  createdAt           BigInt  @map("created_at")
  expiresAt           BigInt  @map("expires_at")
  accessHistoryLimit  Int     @map("access_history_limit")
  bufferConfig        String? @map("buffer_config") // JSON
  bufferSnapshot      String? @map("buffer_snapshot") // JSON (best-effort)
  updatedAt           BigInt  @map("updated_at")

  @@index([expiresAt])
  @@map("synapse_sessions")
}

model SynapseAccessHistory {
  sessionId       String @map("session_id")
  memoryId        String @map("memory_id")
  accessCount     Int    @map("access_count") @default(0)
  lastAccessedAt  BigInt @map("last_accessed_at")

  @@id([sessionId, memoryId])
  @@index([sessionId])
  @@map("synapse_access_history")
}

// ========================================
// Task Checkpoints (Phase 3 — PG parity for the checkpoint store, #16)
// Durable task/INDEX execution state (progress, decisions, files) for the
// checkpoint manager. PostgreSQL-canonical via CheckpointManager
// (PostgreSQL memories table / task_checkpoints); this model provides PG parity so a
// Postgres deployment persists checkpoints in the same backend as the rest of
// the data plane (one-backend rule). The factory branch inside
// CheckpointManager.getInstance() selects PgCheckpointStore when DATABASE_URL
// is postgres, else the PostgreSQL path. State is a gzip-compressed JSON blob
// (parity with the PostgreSQL store's Bun.deflateSync). Timestamps are BigInt
// ms-epochs (parity with IndexJob/ScheduledJob/SynapseSession).
// ========================================
model Checkpoint {
  id                  String  @id @map("id")
  taskId              String  @map("task_id")
  taskDescription     String? @map("task_description")
  agentId             String? @map("agent_id")
  projectId           String? @map("project_id")
  state               Bytes   @map("state") // gzip-compressed JSON
  stateSchemaVersion  Int     @default(1) @map("state_schema_version")
  memoryIds           String? @map("memory_ids") // JSON array
  fileChanges         String? @map("file_changes") // JSON array
  checkpointType      String  @map("checkpoint_type")
  parentCheckpointId  String? @map("parent_checkpoint_id")
  createdAt           BigInt  @map("created_at")
  expiresAt           BigInt? @map("expires_at")

  @@index([taskId])
  @@index([projectId])
  @@index([createdAt])
  @@index([checkpointType])
  @@map("task_checkpoints")
}

// Durable retired-ID compatibility and strict identity-operation audit.
model ProjectIdentityAlias {
  retiredProjectId String   @id @map("retired_project_id")
  targetProjectId  String   @map("target_project_id")
  canonicalRoot    String   @map("canonical_root")
  operationId      String   @map("operation_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  target            Workspace @relation("ProjectIdentityAliasTarget", fields: [targetProjectId], references: [projectId], onDelete: Restrict, onUpdate: Cascade)
  operation         ProjectIdentityOperation @relation(fields: [operationId], references: [operationId], onDelete: Restrict, onUpdate: Restrict)

  @@index([targetProjectId])
  @@map("project_identity_aliases")
}

model ProjectIdentityOperation {
  operationId        String   @id @map("operation_id")
  mode               String
  sourceProjectId    String   @map("source_project_id")
  targetProjectId    String   @map("target_project_id")
  sourceCanonicalRoot String  @map("source_canonical_root")
  targetCanonicalRoot String  @map("target_canonical_root")
  requestHash        String   @map("request_hash")
  planHash           String   @map("plan_hash")
  result             Json
  committedAt        DateTime @default(now()) @map("committed_at") @db.Timestamptz(6)
  aliases            ProjectIdentityAlias[]

  @@index([sourceProjectId])
  @@index([targetProjectId])
  @@map("project_identity_operations")
}

// ========================================
// Managed Runs (Wave 5 FR-08 / FR-09 / FR-10 / FR-20 / AD-W5-004 / AD-W5-013 / AD-W5-014)
// Single table unifying indexing lease (CAS, 90s expiry + 30s heartbeat) and
// idempotent event_id dedup + FileCursor resume. Decoupled from
// graph_generations (AD-W5-004): an indexing run is a process-writer concept
// with a different lifecycle than an immutable generation snapshot.
//
// Reaper (AD-W5-013): every begin() first UPDATEs expired active rows to
// 'aborted'. The managed_runs_status_active partial index supports that query.
//
// getActive pin (AD-W5-014): WHERE status='active' AND lease_expires_at >
// clock_timestamp() ORDER BY lease_expires_at DESC LIMIT 1. The
// managed_runs_one_active_per_project_kind partial UNIQUE index enforces "one
// live active row per (project_id, run_kind)".
//
// event_id uniqueness (FR-10): UNIQUE(project_id, event_id) prevents duplicate
// application across crashes/restarts (idempotent incremental import).
// ========================================
model ManagedRun {
  id             BigInt   @id @default(autoincrement()) @map("id")
  projectId      String   @map("project_id")
  runKind        String   @map("run_kind")
  eventId        String   @map("event_id")
  contentHash    String?  @map("content_hash")
  fileCursor     Json?    @map("file_cursor")
  status         String   @default("active") @map("status")
  leaseToken     String?  @map("lease_token")
  leaseExpiresAt DateTime? @map("lease_expires_at") @db.Timestamptz(6)
  heartbeatAt    DateTime? @map("heartbeat_at") @db.Timestamptz(6)
  createdAt      BigInt   @map("created_at")
  completedAt    BigInt?  @map("completed_at")

  @@unique([projectId, eventId], map: "managed_runs_event_unique")
  @@index([leaseExpiresAt], map: "managed_runs_lease_expiry")
  @@map("managed_runs")
}

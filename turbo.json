{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": [
        "DATABASE_URL",
        "IDENTITY_ACCEPTANCE_DATABASE_URL",
        "MASSA_TH0TH_API_URL",
        "MASSA_TH0TH_API_KEY",
        "MASSA_TH0TH_DEDICATED",
        "LLM_JUDGE_PROBE_URL",
        "OLLAMA_BASE_URL",
        "RLM_LLM_BASE_URL",
        "RLM_LLM_CODE_MODEL",
        "RLM_LLM_ENABLED",
        "RLM_LLM_MODEL",
        "RUN_E2E",
        "RUN_E2E_DESTRUCTIVE"
      ]
    },
    "lint": {}
  }
}

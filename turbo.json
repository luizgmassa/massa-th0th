{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "cache": false,
      "passThroughEnv": [
        "DATABASE_URL",
        "IDENTITY_ACCEPTANCE_DATABASE_URL",
        "HOOK_ATTRIBUTION_ACCEPTANCE_DATABASE_URL",
        "MASSA_AI_API_URL",
        "MASSA_AI_API_KEY",
        "MASSA_AI_DEDICATED",
        "MASSA_AI_EXECUTOR_SANDBOX",
        "LLM_JUDGE_PROBE_URL",
        "OLLAMA_BASE_URL",
        "RLM_LLM_BASE_URL",
        "RLM_LLM_CODE_MODEL",
        "RLM_LLM_ENABLED",
        "RLM_LLM_MODEL",
        "RUN_E2E",
        "RUN_E2E_DESTRUCTIVE"
      ]
    },
    "lint": {}
  }
}
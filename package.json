{
  "name": "th0th",
  "version": "2.0.1",
  "private": true,
  "author": "S1LV4",
  "description": "th0th - Ancient knowledge keeper for modern code. Semantic search with 98% token reduction",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "predev": "bun scripts/diagnose.ts && bash scripts/ensure-ollama.sh",
    "predev:api": "bun scripts/diagnose.ts",
    "predev:mcp": "bun scripts/diagnose.ts",
    "predev:ui": "bun scripts/diagnose.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter @th0th-ai/tools-api...",
    "dev:mcp": "bun run --filter @th0th-ai/mcp-client dev",
    "dev:ui": "bun run --filter @th0th-ai/ui-client dev",
    "start:api": "bun run --filter @th0th-ai/tools-api start",
    "start:mcp": "bun run --filter @th0th-ai/mcp-client start",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "bench:fixture": "bun run --filter @th0th-ai/core bench:fixture:th0th",
    "bench:beir": "bun run --filter @th0th-ai/core bench:beir",
    "lint": "turbo run lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "test:scripts": "bash scripts/tests/test-wsl-ip-detection.sh",
    "diagnose": "bun scripts/diagnose.ts",
    "version:sync": "bun scripts/version-sync.ts"
  },
  "keywords": [
    "mcp",
    "th0th",
    "thoth",
    "model-context-protocol",
    "semantic-search",
    "code-search",
    "token-optimization",
    "ai",
    "llm",
    "context",
    "vector-search",
    "knowledge-retrieval"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "turbo": "^2.5.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.2.0",
  "optionalDependencies": {
    "pg": "^8.20.0"
  }
}

{
  "name": "massa-th0th",
  "version": "1.1.0",
  "private": true,
  "author": "luizgmassa",
  "description": "massa-th0th - Ancient knowledge keeper for modern code. Semantic search with 98% token reduction",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "predev": "bun scripts/diagnose.ts && bash scripts/ensure-ollama.sh",
    "predev:api": "bun scripts/diagnose.ts",
    "predev:mcp": "bun scripts/diagnose.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter @massa-th0th/tools-api...",
    "dev:mcp": "bun run --filter @massa-th0th/mcp-client dev",
    "start:api": "bun run --filter @massa-th0th/tools-api start",
    "start:mcp": "bun run --filter @massa-th0th/mcp-client start",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "bench:fixture": "bun run --filter @massa-th0th/core bench:fixture:massa-th0th",
    "bench:beir": "bun run --filter @massa-th0th/core bench:beir",
    "bench:needles": "bun benchmarks/needles/run.ts",
    "bench:needles:gate": "NEEDLE_FLOOR_HIT1=0.5 NEEDLE_FLOOR_MRR=0.65 bun benchmarks/needles/run.ts --label ci-gate",
    "bench:parser": "bun benchmarks/parser/run.ts --baseline 5d43a96f4c0f1dfbd04ee7ae95f589f9b023bf03",
    "lint": "turbo run lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "test:scripts": "bash scripts/tests/test-wsl-ip-detection.sh",
    "diagnose": "bun scripts/diagnose.ts",
    "version:sync": "bun scripts/version-sync.ts",
    "verify:tree-sitter-source-dist": "bun scripts/verify-tree-sitter-grammars.ts",
    "verify:tree-sitter-package": "bun scripts/verify-tree-sitter-package-artifact.ts",
    "verify:tree-sitter-native": "bun scripts/verify-tree-sitter-grammars.ts && bun scripts/verify-tree-sitter-package-artifact.ts"
  },
  "keywords": [
    "mcp",
    "massa-th0th",
    "thoth",
    "model-context-protocol",
    "semantic-search",
    "code-search",
    "token-optimization",
    "ai",
    "llm",
    "context",
    "vector-search",
    "knowledge-retrieval"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "turbo": "^2.5.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@tree-sitter-grammars/tree-sitter-kotlin",
    "@tree-sitter-grammars/tree-sitter-lua",
    "@tree-sitter-grammars/tree-sitter-markdown",
    "@tree-sitter-grammars/tree-sitter-yaml",
    "@tree-sitter-grammars/tree-sitter-zig",
    "tree-sitter",
    "tree-sitter-c",
    "tree-sitter-c-sharp",
    "tree-sitter-clojure-orchard",
    "tree-sitter-cpp",
    "tree-sitter-dart",
    "tree-sitter-elixir",
    "tree-sitter-erlang",
    "tree-sitter-go",
    "tree-sitter-haskell",
    "tree-sitter-html",
    "tree-sitter-java",
    "tree-sitter-javascript",
    "tree-sitter-json",
    "tree-sitter-ocaml",
    "tree-sitter-php",
    "tree-sitter-python",
    "tree-sitter-ruby",
    "tree-sitter-rust",
    "tree-sitter-scala",
    "tree-sitter-swift",
    "tree-sitter-typescript"
  ],
  "patchedDependencies": {
    "tree-sitter@0.25.0": "patches/tree-sitter@0.25.0.patch"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
